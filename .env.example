# Tripzo Environment Variables - Template
# Copy this file to .env and fill in your real values

# Database
CONNECTION_STRING=YOUR_CONNECTION_STRING_HERE

# JWT Authentication
JWT_KEY=YOUR_JWT_SECRET_KEY_MINIMUM_32_CHARS
JWT_ISSUER=Tripzo
JWT_AUDIENCE=TripzoUsers

# Razorpay Payments
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# Email Configuration (SMTP)
EMAIL_SENDER_NAME=Tripzo
EMAIL_SENDER_EMAIL=YOUR_EMAIL_HERE
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=YOUR_EMAIL_HERE
EMAIL_PASSWORD=YOUR_APP_PASSWORD_HERE

# Frontend
REACT_APP_API_URL=https://localhost:7226/api
